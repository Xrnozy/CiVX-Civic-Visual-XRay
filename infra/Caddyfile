# TLS terminates at Cloudflare — tunnel forwards plain HTTP to :80.
# CADDY_ROOT is set by infra/run-caddy.bat (absolute path to web/dist).
{
	auto_https off
}

http://civx.xrnozy.me, http://127.0.0.1, http://localhost {
	encode gzip

	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle /ws/* {
		reverse_proxy 127.0.0.1:8000
	}

	handle /health {
		reverse_proxy 127.0.0.1:8000
	}

	handle /assets/* {
		root * "{$CADDY_ROOT}"
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		root * "{$CADDY_ROOT}"
		header Cross-Origin-Opener-Policy same-origin-allow-popups
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
