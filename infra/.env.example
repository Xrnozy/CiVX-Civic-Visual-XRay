# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://civx.xrnozy.me
JWT_SECRET=change-me-in-production
# Auto-grant lgu_staff to signed-in users (hackathon demo). Set false in production.
DEMO_LGU_AUTO_ROLE=false
PUBLIC_WEB_URL=http://localhost:5173
MOBILE_DEMO_BASE_URL=https://civx.xrnozy.me/mobile

# Passive pipeline (Redis + YOLO workers)
REDIS_URL=redis://127.0.0.1:6379/0
PIPELINE_STORAGE_ROOT=storage
GPU_LOCK_ENABLED=true
GPU_LOCK_TTL_SECONDS=120
GPU_LOCK_WAIT_SECONDS=300
BLUR_LAPLACIAN_MIN=80.0
FRAME_HASH_MAX_DISTANCE=5
QUEUE_YOLO_BUSY=500
QUEUE_LOCATE_BUSY=100

# AI Worker — YOLO
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.35
YOLO_CONFIDENCE_HIGH=0.85
YOLO_CONFIDENCE_MEDIUM=0.50
YOLO_BATCH_NORMAL=16
YOLO_BATCH_BUSY=32

# AI Worker — LocateAnything (verification only for medium-confidence hits)
LOCATEANYTHING_MODEL=nvidia/LocateAnything-3B
LOCATEANYTHING_DEVICE=auto
LOCATEANYTHING_GENERATION_MODE=fast
LOCATEANYTHING_MAX_NEW_TOKENS=512
LOCATEANYTHING_MIN_CONFIDENCE=0.35
LOCATEANYTHING_IMAGE_MAX_SIDE=1024
LOCATEANYTHING_MAX_BOXES_PER_FRAME=2

FFMPEG_PATH=ffmpeg

# Optional LLM summaries
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Web (Vite) — vite.config.ts loads this file via envDir: ../infra
# Leave VITE_API_URL empty for local dev (Vite proxies /api). Set for production builds.
VITE_API_URL=
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
# ^ From Firebase Console → Project settings → General → Web API Key (not the Google Maps key)
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key
# Public mobile demo URL used in QR codes. For local phone testing, use a LAN/tunnel URL.
VITE_MOBILE_DEMO_URL=https://civx.xrnozy.me/mobile

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-oauth-client-id
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your-google-expo-oauth-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-oauth-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-oauth-client-id
